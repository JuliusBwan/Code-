private void handleUpdates(List<OrderItem> newItems, List<OrderItem> oldItems){

        Set<Id> ids = new Set<Id>();
        for(OrderItem oi : newItems){
            ids.add(oi.Id);
        }

        Map<Id, CustomerOrderLine__c> existing =
            CustomerOrderLineRepository.getByOrderItemIds(ids);

        List<CustomerOrderLine__c> updates = new List<CustomerOrderLine__c>();

        for(Integer i = 0; i < newItems.size(); i++){

            OrderItem newOI = newItems[i];
            OrderItem oldOI = oldItems[i];

            if(existing.containsKey(newOI.Id)){

                CustomerOrderLine__c col = existing.get(newOI.Id);

                Boolean changed = false;

                if(oldOI.EndDate != newOI.EndDate){
                    col.End_Date__c = newOI.EndDate;
                    changed = true;
                }

                if(oldOI.Quantity != newOI.Quantity){
                    col.Quantity__c = newOI.Quantity;
                    changed = true;
                }

                if(oldOI.TotalPrice != newOI.TotalPrice){
                    col.Total_Price__c = newOI.TotalPrice;
                    changed = true;
                }

                if(changed){
                    col.Last_Synced_Date__c = System.now();
                    updates.add(col);
                }
            }
        }

        if(updates.isEmpty()) return;

        Database.SaveResult[] results =
            CustomerOrderLineRepository.updateCOLs(updates);

        NotificationService.handleResults(
            'Customer Order Lines - Update Summary',
            updates.size(),
            results
        );
    }

    private void handleDeletes(List<Id> deletedIds){

        List<CustomerOrderLine__c> cols =
            CustomerOrderLineRepository.getByOrderItemIds(deletedIds).values();

        List<CustomerOrderLine__c> updates = new List<CustomerOrderLine__c>();

        for(CustomerOrderLine__c col : cols){

            col.Name = CustomerOrderLineUtils.prependDeletedTag(col.Name);
            updates.add(col);
        }

        if(updates.isEmpty()) return;

        Database.SaveResult[] results =
            CustomerOrderLineRepository.updateCOLs(updates);

        NotificationService.handleResults(
            'Customer Order Lines - Delete Marking Summary',
            updates.size(),
            results
        );
    }
}


