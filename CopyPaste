public class NotificationService {

    public static void handleResults(
        String subject,
        Integer totalAttempted,
        Database.SaveResult[] results
    ){

        Integer failCount = 0;

        for(Database.SaveResult sr : results){
            if(!sr.isSuccess()){
                failCount++;
            }
        }

        if(failCount == 0){
            return;
        }

        Messaging.SingleEmailMessage mail =
            new Messaging.SingleEmailMessage();

        mail.setToAddresses(
            new String[] { UserInfo.getUserEmail() }
        );

        mail.setSubject(subject);

        String body =
            'One or more records failed during the operation.\n\n' +
            'Total attempted: ' + totalAttempted + '\n' +
            'Failed: ' + failCount + '\n' +
            'Successful: ' + (totalAttempted - failCount);

        mail.setPlainTextBody(body);

        Messaging.sendEmail(
            new Messaging.SingleEmailMessage[]{ mail }
        );
    }
}
