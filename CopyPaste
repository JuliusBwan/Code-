public with sharing class CustomerOrderLineRepository {

    public static Map<Id, CustomerOrderLine__c> getByOrderItemIds(Set<Id> ids){

        Map<Id, CustomerOrderLine__c> result = new Map<Id, CustomerOrderLine__c>();

        for(CustomerOrderLine__c col :
            [SELECT Id, Name, OrderItem__c
             FROM CustomerOrderLine__c
             WHERE OrderItem__c IN :ids]){

            result.put(col.OrderItem__c, col);
        }

        return result;
    }

    public static Database.SaveResult[] insertCOLs(List<CustomerOrderLine__c> cols){

        return Database.insert(cols,false);
    }

    public static Database.SaveResult[] updateCOLs(List<CustomerOrderLine__c> cols){

        return Database.update(cols,false);
    }
}

