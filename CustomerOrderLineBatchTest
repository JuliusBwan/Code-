// ─── CustomerOrderLineBatchTest ───────────────────────────────────────────────
/**
 * Tests for CustomerOrderLineBatch.
 *
 * Covers:
 *  - Pass 1 (insert) : COLs are created for OrderItems that have none.
 *  - Pass 2 (update) : Drifted COL fields are corrected in the same batch run.
 *  - Pass 3 (orphan) : COLs with no OrderItem get the [DEL] tag.
 *  - finish()        : Runs without exception; counters are correct.
 *
 * All batch tests wrap execution in Test.startTest() / Test.stopTest()
 * because Database.executeBatch() is asynchronous.
 */
@isTest
private class CustomerOrderLineBatchTest {

    // ── TEST DATA ─────────────────────────────────────────────────────────────

    @testSetup
    static void setupData() {
        Account acc = new Account(Name = 'Batch Test Account');
        insert acc;

        Id pbId = Test.getStandardPricebookId();

        Order ord = new Order(
            AccountId     = acc.Id,
            Status        = 'Draft',
            EffectiveDate = Date.today(),
            Pricebook2Id  = pbId
        );
        insert ord;

        Product2 prod = new Product2(Name = 'Batch Product', IsActive = true);
        insert prod;

        PricebookEntry pbe = new PricebookEntry(
            Pricebook2Id = pbId,
            Product2Id   = prod.Id,
            UnitPrice    = 200,
            IsActive     = true
        );
        insert pbe;

        OrderItem oi = new OrderItem(
            OrderId          = ord.Id,
            PricebookEntryId = pbe.Id,
            Quantity         = 2,
            UnitPrice        = 200,
            ServiceDate      = Date.today(),
            EndDate          = Date.today().addMonths(12)
        );
        insert oi;
    }

    // ── PASS 1 — insert missing COLs ─────────────────────────────────────────

    @isTest
    static void batch_createsColForOrderItemWithNone() {
        OrderItem oi = [SELECT Id FROM OrderItem LIMIT 1];
        // No COL exists yet
        System.assertEquals(0, [SELECT COUNT() FROM CustomerOrderLine__c WHERE OrderItem__c = :oi.Id]);

        Test.startTest();
        Database.executeBatch(new CustomerOrderLineBatch(), 200);
        Test.stopTest();

        System.assertEquals(
            1,
            [SELECT COUNT() FROM CustomerOrderLine__c WHERE OrderItem__c = :oi.Id],
            'Batch should create one COL for the unmatched OrderItem'
        );
    }

    // ── PASS 2 — update drifted COL ───────────────────────────────────────────

    @isTest
    static void batch_updatesDriftedCOLFields() {
        OrderItem oi = [SELECT Id, Quantity, TotalPrice, ServiceDate, EndDate,
                               blng__LastChargeToDate__c, blng__NextBillingDate__c,
                               SBQQ__DefaultSubscriptionTerm__c, OrderItemNumber,
                               Order.AccountId, SBQQ__Contract__r.Status, Product2.Name
                        FROM OrderItem LIMIT 1];

        // Insert a COL with stale Quantity
        CustomerOrderLine__c col = CustomerOrderLineService.buildCOL(oi);
        col.Quantity__c = 999; // deliberately stale
        insert col;

        Test.startTest();
        Database.executeBatch(new CustomerOrderLineBatch(), 200);
        Test.stopTest();

        CustomerOrderLine__c updated = [
            SELECT Quantity__c FROM CustomerOrderLine__c WHERE OrderItem__c = :oi.Id
        ];
        System.assertNotEquals(999, updated.Quantity__c, 'Batch should correct the drifted Quantity');
    }

    // ── PASS 3 — orphan cleanup ───────────────────────────────────────────────

    @isTest
    static void batch_tagsOrphanedCOLsWithDelPrefix() {
        // COL with no OrderItem__c
        CustomerOrderLine__c orphan = new CustomerOrderLine__c(Name = 'COL-ORPHAN-BATCH');
        insert orphan;

        Test.startTest();
        Database.executeBatch(new CustomerOrderLineBatch(), 200);
        Test.stopTest();

        CustomerOrderLine__c checked = [SELECT Name FROM CustomerOrderLine__c WHERE Id = :orphan.Id];
        System.assert(checked.Name.startsWith('[DEL]'), 'Orphaned COL should be tagged [DEL] by batch');
    }

    // ── finish counters ───────────────────────────────────────────────────────

    @isTest
    static void batch_countersReflectInserts() {
        // Verify insertSuccess increments (indirectly through @TestVisible)
        OrderItem oi = [SELECT Id FROM OrderItem LIMIT 1];
        System.assertEquals(0, [SELECT COUNT() FROM CustomerOrderLine__c WHERE OrderItem__c = :oi.Id]);

        CustomerOrderLineBatch batchJob = new CustomerOrderLineBatch();

        Test.startTest();
        Database.executeBatch(batchJob, 200);
        Test.stopTest();

        // After batch completes, insertSuccess should be >= 1
        System.assert(batchJob.insertSuccess >= 1, 'insertSuccess counter should be at least 1');
        System.assertEquals(0, batchJob.insertFail, 'insertFail should be 0 for valid data');
    }
}
