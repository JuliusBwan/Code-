@IsTest
public with sharing class CustomerOrderLineTestDataFactory {
    
    public class OrderBundle {
        public Account account;
        public Product2 product;
        public Pricebook2 pricebook;
        public PricebookEntry pbe;
        public Order orderRec;
        public OrderItem orderItem;
    }

    public static OrderBundle createOrderWithItem() {
        OrderBundle b = new OrderBundle();

        b.account = new Account(Name = 'Test Account');
        insert b.account;

        Id stdPbId = Test.getStandardPricebookId();
        b.pricebook = [SELECT Id, IsActive FROM Pricebook2 WHERE Id = :stdPbId LIMIT 1];
        if (!b.pricebook.IsActive) { b.pricebook.IsActive = true; update b.pricebook; }

        b.pbe = new PricebookEntry(Pricebook2Id = stdPbId, Product2Id = b.product.Id, UnitPrice = 100, IsActive = true);
        insert b.pbe;

        b.orderRec = new Order(AccountId = b.account.Id, EffectiveDate = Date.today(), Status = 'Draft', Pricebook2Id  = stdPbId);
        insert b.orderRec;

        b.orderItem = new OrderItem(OrderId = b.orderRec.Id, PricebookEntryId = b.pbe.Id, Quantity = 2, UnitPrice = 100);
        insert b.orderItem;

        return b;
    }

    public static CustomerOrderLine__c createColLinkedTo(OrderItem oi, String nameOpt) {
        CustomerOrderLine__c col = new CustomerOrderLine__c();
        col.Name = (nameOpt == null) ? 'Existing COL' : nameOpt;
        col.OrderItem__c = oi.Id;
        insert col;
        return col;
    }

}
