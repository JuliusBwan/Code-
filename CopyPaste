public class CustomerOrderLineUtils {

    public static String prependDeletedTag(String originalName){

        if(String.isBlank(originalName)){
            return '[DEL]';
        }

        if(originalName.startsWith('[DEL]')){
            return originalName;
        }

        return '[DEL] ' + originalName;
    }

    public static String formatColName(OrderItem o){

        String key =
            (o.OrderItemNumber != null)
            ? o.OrderItemNumber
            : String.valueOf(o.Id);

        String prod =
            (o.Product2 != null && o.Product2.Name != null)
            ? '-' + o.Product2.Name
            : '';

        return 'COL-' + key + prod;
    }
}


