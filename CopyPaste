/**
 * CustomerOrderLineHandler
 * ------------------------
 * Flow-invocable entry point for Customer Order Line orchestration.
 *
 * - Exposes a single @InvocableMethod `process` (required by Flow).
 * - Uses RequestWrapper to carry create/update/delete context and records.
 * - Delegates actual work to CustomerOrderLineService.processRequests().
 *
 * Assumptions / Notes:
 * - The Flow passes a non-null list of RequestWrapper items.
 * - For 'create', newRecord must include a persisted OrderItem Id (after-insert).
 * - For 'update', both newRecord and oldRecord are provided and aligned by index.
 * - For 'delete', deletedRecordId is provided.
 */
public class CustomerOrderLineHandler {
	/**
     * Wrapper class to accept data from a Flow.
     * This allows passing different values depending on
     * whether the record is being created, updated, or deleted.
     */
    public class RequestWrapper {
        @InvocableVariable(required=true)
        public String operationType;
        // "create", "update", or "delete"
        
        @InvocableVariable
        public OrderItem newRecord;
        // Used for Create or Update operation
        
        @InvocableVariable
        public OrderItem oldRecord;
        // Only used for Update operations

        @InvocableVariable
        public Id deletedRecordId;
        // Used for Delete operations

    }
    
	/**
     * Single entry point for Flow.
     * Salesforce only allows ONE @InvocableMethod per class,
     * so this method determines which internal handler method to call.
     */

	@InvocableMethod(label='Process OrderItem Event')
    public static void process(List<CustomerOrderLineHandler.RequestWrapper> requests){  
        
        // null-safety guard to prevent NPE if Flow ever passes null
        if (requests == null) { return; }

        CustomerOrderLineService.processRequests(requests);
    }
}

