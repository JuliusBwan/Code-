/**
 * NotificationService
 * -------------------
 * Summarizes partial DML results and emails the running user when any failures occur (fails > 0). No email is sent when all DML operations succeed.
 *
 * Notes:
 * - Consumes email invocation limits when there are failures.
 * - In tests, Salesforce does not send real emails, but invocations are counted.
 */
public with sharing class NotificationService {

    public static void handleResults(String subject, Integer totalAttempted, Database.SaveResult[] results){
        Integer failCount = 0;

        if (results == null || results.isEmpty()) return;

        for(Database.SaveResult sr : results){
            if(sr == null || !sr.isSuccess()){ failCount++; }
        }

        if(failCount == 0){ return; }

        Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
        mail.setToAddresses(new String[] { UserInfo.getUserEmail() });
        mail.setSubject(subject);

        String body = 'One or more records failed during the operation.\n\n' +
            'Total attempted: ' + totalAttempted + '\n' +
            'Failed: ' + failCount + '\n' +
            'Successful: ' + (totalAttempted - failCount);

        mail.setPlainTextBody(body);
        Messaging.sendEmail(new Messaging.SingleEmailMessage[]{ mail });
    }
}

