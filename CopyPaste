public with sharing class CustomerOrderLineHandler {

    /**
     * Wrapper class to accept data from a Flow.
     * This allows passing different values depending on
     * whether the record is being created, updated, or deleted.
     */
    public class RequestWrapper {
        @InvocableVariable(required=true)
        public String operationType;   
        // "create", "update", or "delete"

        @InvocableVariable
        public OrderItem newRecord;    
        // Used for Create or Update operations

        @InvocableVariable
        public OrderItem oldRecord;    
        // Only used for Update operations

        @InvocableVariable
        public Id deletedRecordId;     
        // Used for Delete operations
    }


    /**
     * Single entry point for Flow.
     * Salesforce only allows ONE @InvocableMethod per class,
     * so this method determines which internal handler method to call.
     */
    @InvocableMethod(label='Process OrderItem Event')
    public static void process(List<RequestWrapper> requests) {

        // Lists for bulk processing
        List<OrderItem> createList = new List<OrderItem>();
        List<OrderItem> updateNew = new List<OrderItem>();
        List<OrderItem> updateOld = new List<OrderItem>();
        List<Id> deleteList = new List<Id>();

        // Loop through wrapper payloads from the Flow
        for (RequestWrapper req : requests) {

            // Sort into correct operation buckets
            if (req.operationType == 'create' && req.newRecord != null) {
                createList.add(req.newRecord);
            }
            else if (req.operationType == 'update' &&
                     req.newRecord != null &&
                     req.oldRecord != null) {
                updateNew.add(req.newRecord);
                updateOld.add(req.oldRecord);
            }
            else if (req.operationType == 'delete' &&
                     req.deletedRecordId != null) {
                deleteList.add(req.deletedRecordId);
            }
        }

        // Call internal handler methods based on collected data
        if (!createList.isEmpty()) {
            handleCreates(createList);
        }
        if (!updateNew.isEmpty()) {
            handleUpdates(updateNew, updateOld);
        }
        if (!deleteList.isEmpty()) {
            handleDeletes(deleteList);
        }
    }


    /**
     * CREATE LOGIC
     * Creates new CustomerOrderLine__c records when new OrderItems are created.
     */
    private static void handleCreates(List<OrderItem> newItems) {

        // Collect OrderItem IDs
        Set<Id> oiIds = new Set<Id>();
        for (OrderItem oi : newItems) oiIds.add(oi.Id);

        // Query existing COLs for duplication prevention
        Map<Id, CustomerOrderLine__c> existing = new Map<Id, CustomerOrderLine__c>(
            [SELECT Id, OrderItem__c FROM CustomerOrderLine__c WHERE OrderItem__c IN :oiIds]
        );

        // Build new COLs
        List<CustomerOrderLine__c> toInsert = new List<CustomerOrderLine__c>();

        for (OrderItem oi : newItems) {
            if (!existing.containsKey(oi.Id)) {
                CustomerOrderLine__c col = new CustomerOrderLine__c();
                col.OrderItem__c = oi.Id;
                col.Name = 'COL-' + oi.OrderItemNumber;
                col.Product_Name__c = oi.Product2 != null ? oi.Product2.Name : null;
                col.Quantity__c = oi.Quantity;
                col.Total_Price__c = oi.TotalPrice;
                col.Service_Date__c = oi.ServiceDate;
                col.End_Date__c = oi.EndDate;
                col.Subscription_Term_Months__c = oi.SBQQ__DefaultSubscriptionTerm__c;
                col.Account__c = oi.SBQQ__Subscription__r != null ? oi.SBQQ__Subscription__r.SBQQ__Account__c : null;
                toInsert.add(col);
            }
        }

        if (!toInsert.isEmpty()) insert toInsert;
    }


    /**
     * UPDATE LOGIC
     * Updates existing CustomerOrderLine__c when OrderItem fields change.
     */
    private static void handleUpdates(List<OrderItem> newItems, List<OrderItem> oldItems) {

        // Collect OrderItem IDs
        Set<Id> oiIds = new Set<Id>();
        for (OrderItem oi : newItems) oiIds.add(oi.Id);

        // Query existing COLs
        Map<Id, CustomerOrderLine__c> colMap = new Map<Id, CustomerOrderLine__c>(
            [SELECT Id, OrderItem__c, Quantity__c, Total_Price__c, Product_Name__c
             FROM CustomerOrderLine__c WHERE OrderItem__c IN :oiIds]
        );

        List<CustomerOrderLine__c> toUpdate = new List<CustomerOrderLine__c>();

        // Loop through each paired new/old entry
        for (Integer i = 0; i < newItems.size(); i++) {
            OrderItem newOI = newItems[i];
            OrderItem oldOI = oldItems[i];

            if (colMap.containsKey(newOI.Id)) {
                CustomerOrderLine__c col = colMap.get(newOI.Id);

                // Compare values and update if necessary
                Boolean changed = false;

                if (col.Quantity__c != newOI.Quantity) {
                    col.Quantity__c = newOI.Quantity;
                    changed = true;
                }
                if (col.Total_Price__c != newOI.TotalPrice) {
                    col.Total_Price__c = newOI.TotalPrice;
                    changed = true;
                }
                if (col.Product_Name__c != (newOI.Product2 != null ? newOI.Product2.Name : null)) {
                    col.Product_Name__c = newOI.Product2 != null ? newOI.Product2.Name : null;
                    changed = true;
                }

                if (changed) toUpdate.add(col);
            }
        }

        if (!toUpdate.isEmpty()) update toUpdate;
    }


    /**
     * DELETE LOGIC
     * Deletes the CustomerOrderLine__c when its OrderItem is deleted.
     */
    private static void handleDeletes(List<Id> deletedIds) {

        // Query COL records linked to deleted OrderItems
        List<CustomerOrderLine__c> toDelete = [
            SELECT Id FROM CustomerOrderLine__c WHERE OrderItem__c IN :deletedIds
        ];

        if (!toDelete.isEmpty()) delete toDelete;
    }
}
